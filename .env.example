# SO360 V.2 Frontend Environment Variables Template
# Copy this file to .env and fill in the values

# ==============================================
# SUPABASE CONFIGURATION
# ==============================================
# Get these from: https://app.supabase.com → Your Project → Settings → API

# Supabase Project URL
VITE_SUPABASE_URL=https://xxxxx.supabase.co

# Supabase Anonymous Key (Public key - safe to use in frontend)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ==============================================
# API ENDPOINTS
# ==============================================
# Backend API base URLs - update based on environment

# For DEPLOYMENT (dev/staging), use API Gateway:
# Core Backend API (IAM, Tenancy, Governance)
VITE_SO360_CORE_API=https://dev.api.skyoffice360.com/core

# CRM Backend API
VITE_CRM_API=https://dev.api.skyoffice360.com/crm

# Inventory Backend API
VITE_INVENTORY_API=https://dev.api.skyoffice360.com/inventory

# Accounting Backend API
VITE_ACCOUNTING_API=https://dev.api.skyoffice360.com/accounting

# Projects Backend API
VITE_PROJECTS_API=https://dev.api.skyoffice360.com/projects

# Timesheet Backend API
VITE_TIMESHEET_API=https://dev.api.skyoffice360.com/timesheet

# People Connect Backend API
VITE_PEOPLE_API=https://dev.api.skyoffice360.com/people

# DailyStore Backend API
VITE_DAILYSTORE_API=https://dev.api.skyoffice360.com/dailystore

# For LOCAL DEVELOPMENT, use localhost:
# VITE_SO360_CORE_API=http://localhost:4000
# VITE_CRM_API=http://localhost:4001
# VITE_INVENTORY_API=http://localhost:4006
# VITE_ACCOUNTING_API=http://localhost:4008
# VITE_PROJECTS_API=http://localhost:4010
# VITE_TIMESHEET_API=http://localhost:4012
# VITE_PEOPLE_API=http://localhost:4007
# VITE_DAILYSTORE_API=http://localhost:4014

# For STAGING, use staging API Gateway:
# VITE_SO360_CORE_API=https://staging.api.skyoffice360.com/core
# VITE_CRM_API=https://staging.api.skyoffice360.com/crm
# VITE_INVENTORY_API=https://staging.api.skyoffice360.com/inventory
# VITE_ACCOUNTING_API=https://staging.api.skyoffice360.com/accounting
# VITE_PROJECTS_API=https://staging.api.skyoffice360.com/projects
# VITE_TIMESHEET_API=https://staging.api.skyoffice360.com/timesheet
# VITE_PEOPLE_API=https://staging.api.skyoffice360.com/people
# VITE_DAILYSTORE_API=https://staging.api.skyoffice360.com/dailystore

# ==============================================
# NOTES
# ==============================================
# 1. NEVER commit .env files to git
# 2. Each environment (local, dev, staging, prod) needs its own .env file
# 3. Update API URLs when deploying to different environments
# 4. VITE_ prefix is required for Vite to expose variables to browser
# 5. Changes to .env require restarting the dev server
